            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/members/{{userId}}", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "members", "{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"MEMBER\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Send Invitation",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/invites", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "invites"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"role\": \"MEMBER\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Invitations",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/invites", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "invites"] }
          }
        },
        {
          "name": "Accept Invitation",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/tenants/invites/accept", "host": ["{{baseUrl}}"], "path": ["tenants", "invites", "accept"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"invitation-token-here\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Revoke Invitation",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/invites/{{inviteId}}", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "invites", "{{inviteId}}"] }
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/audit-logs?page=1&limit=50", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "audit-logs"], "query": [
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "50" }
            ]}
          }
        },
        {
          "name": "Create Resource Share",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/tenants/{{tenantId}}/shares", "host": ["{{baseUrl}}"], "path": ["tenants", "{{tenantId}}", "shares"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"PROJECT\",\n  \"resourceId\": \"project-uuid\",\n  \"userId\": \"user-uuid\",\n  \"permission\": \"read\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
